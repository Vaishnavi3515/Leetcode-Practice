class Solution {
public:
    bool check(int speed, vector<int>& piles, int h) {
        long long count = 0; // use long long to avoid overflow
        for(int pile : piles) {
            // Ceiling division: (pile + speed - 1) / speed
            count += (pile + speed - 1) / speed;
        }
        return count <= h;
    }

    int minEatingSpeed(vector<int>& piles, int h) {
        int mx = 0;
        for(int pile : piles) {
            mx = max(mx, pile); // find max pile
        }

        int lo = 1;
        int hi = mx;
        int ans = -1;

        while(lo <= hi) {
            int mid = lo + (hi - lo) / 2;
            if(check(mid, piles, h)) {
                ans = mid;
                hi = mid - 1; // try smaller speed
            } else {
                lo = mid + 1; // need bigger speed
            }
        }

        return ans;
    }
};
